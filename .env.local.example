# Transcript Studio — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must never be committed.

# Neon pooled Postgres connection string (use the "-pooler" host).
# Example: postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/transcript_studio?sslmode=require"

# AssemblyAI API key — used for audio transcription.
# Get one at https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY="your-assemblyai-api-key"

# OpenAI API key — used for the LLM chat over transcripts.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# Chat model name (optional; defaults to gpt-4o-mini).
LLM_MODEL="gpt-4o-mini"

# Single-user app credentials (basic gate for the app).
APP_USERNAME="admin"
APP_PASSWORD="change-me"

# Secret used to sign the session cookie. Use a long random string.
# Generate one with: openssl rand -base64 32
AUTH_SECRET="generate-a-long-random-string"

# --- Optional global daily caps (single shared login → global spend guards) ---
# All have sensible defaults; override only if needed.
# MAX_UPLOAD_SECONDS_PER_DAY="1800"   # total audio transcribed per day (default 30 min)
# MAX_UPLOADS_PER_DAY="20"            # upload/recording jobs per day
# MAX_CHATS_PER_DAY="100"             # chat messages per day
# MAX_UPLOAD_MB="25"                  # max upload file size in MB
